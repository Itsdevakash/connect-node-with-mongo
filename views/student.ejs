<html>
    <head>
        <title>Node JS</title>
    </head>
    <body>
    <center> <h1>Data will be here</h1> </center>   
       <button><a href="/add">Add</a></button>
    <table border="1" width="100%">
        <tr style="text-align: center;">
            <th>Name</th>
            <th>Age</th>
            <th>Email</th>
            <th>Delete</th>
        </tr>
       <% result.forEach(student=>{ %>
 <tr style="text-align: center;">
            <td><%= student.name %></td>
            <td><%= student.age %></td>
            <td><%=student.email %></td>
            <td>
                <a href="/delete/<%= student._id %>">Delete</a> &nbsp; &nbsp;
                <a href="/edit/<%= student._id %>">Update</a> &nbsp; &nbsp;                     
            
            </td>
        </tr>
      <% }) %>
       
    </table>
    </body>
</html>